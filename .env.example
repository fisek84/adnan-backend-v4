# Example environment configuration (no secrets)

# OpenAI
OPENAI_API_KEY=
# assistants | responses
OPENAI_API_MODE=assistants
# Used when OPENAI_API_MODE=responses
OPENAI_RESPONSES_MODEL=

# Existing assistants
CEO_ADVISOR_ASSISTANT_ID=
NOTION_OPS_ASSISTANT_ID=

# New worker agent: Revenue & Growth Operator
REVENUE_GROWTH_OPERATOR_ASSISTANT_ID=
# Optional: per-agent model override when OPENAI_API_MODE=responses
REVENUE_GROWTH_OPERATOR_MODEL=

# ============================
# Security / Auth (optional)
# ============================
# When true, certain endpoints require X-CEO-Token header matching CEO_APPROVAL_TOKEN.
# NOTE: for WebSocket realtime v1, browsers can't set headers, so token is passed as query:
#   ws://.../api/voice/realtime/ws?ceo_token=<CEO_APPROVAL_TOKEN>
CEO_TOKEN_ENFORCEMENT=false
CEO_APPROVAL_TOKEN=

# Ops write-guards (not required for voice runtime testing)
OPS_SAFE_MODE=false

# ============================
# Chat Streaming (NDJSON)
# ============================
# Enables POST /api/chat/stream (canonical /api/chat remains unchanged)
CHAT_STREAMING_ENABLED=false

# ============================
# Voice Runtime: STT (Whisper)
# ============================
# /api/voice/exec uses OpenAI Whisper via OPENAI_API_KEY
# - Model is currently hardcoded as "whisper-1" in integrations/voice_service.py
# OPENAI_API_KEY is already listed above.

# ============================
# Voice Runtime: TTS (server-generated voice_output)
# ============================
# When enabled AND when caller requests want_voice_output=true, responses may include:
#   voice_output: { available, content_type, audio_base64 }
VOICE_TTS_ENABLED=false

# TTS model/voice/format (OpenAI Audio Speech)
VOICE_TTS_MODEL=tts-1
VOICE_TTS_VOICE=alloy
VOICE_TTS_FORMAT=mp3

# Guardrails for voice_output payload size
VOICE_TTS_MAX_TEXT_CHARS=2000
VOICE_TTS_MAX_AUDIO_BYTES=524288

# ============================
# Voice Runtime: Realtime WS Adapter v1
# ============================
# Enables ws(s)://<host>/api/voice/realtime/ws
VOICE_REALTIME_WS_ENABLED=false

# Session guardrails
VOICE_REALTIME_WS_IDLE_TIMEOUT_SEC=60
VOICE_REALTIME_WS_TURN_TIMEOUT_SEC=120
